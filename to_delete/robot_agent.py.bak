#!/usr/bin/env python
"""Robot Agent Skill - optimized using Typer CLI."""

import os
import sys
import time
import json
import threading
import socket
import subprocess
from pathlib import Path
from typing import Optional

import typer
from rich import print  # 使用 rich 美化输出

# 配置路径
SCRIPT_DIR = Path(__file__).parent
RECORDINGS_DIR = SCRIPT_DIR / "recordings"
RECORDINGS_DIR.mkdir(exist_ok=True)
sys.path.insert(0, str(SCRIPT_DIR))

# 尝试导入，如果不存在则提示
try:
    from robot_client import RobotClient
    from robot_utils import test_arm_port, test_camera
except ImportError as e:
    print(f"[red]Error: Cannot find required module. {e}[/red]")
    sys.exit(1)

# --- RobotAgent 类定义 (保持逻辑不变，增加部分健壮性) ---

class RobotAgent:
    def __init__(self, host="127.0.0.1", port=8765, port_name="/dev/ttyACM1", robot_id="my_awesome_follower_arm"):
        self.host = host
        self.port = port
        self.port_name = port_name
        self.robot_id = robot_id
        self.tmux_session = "robot_server"
        self.client = None
        self._safe_pos = {
            "shoulder_pan.pos": 1.126972201352359,
            "shoulder_lift.pos": -97.32999582811848,
            "elbow_flex.pos": 100.0,
            "wrist_flex.pos": 71.68443496801706,
            "wrist_roll.pos": 0.024420024420024333,
            "gripper.pos": 0.9946949602122015,
        }
        self._record_file = RECORDINGS_DIR / "last_recorded.json"
        self._recording = False
        self._record_data = None
        self._record_thread = None
        self._replay_freq = 100

    # ... (保持你原有的 is_server_online, check_server, connect 等方法不变) ...
    # 为了篇幅，这里略过你代码中已有的逻辑方法，直接进入 CLI 结构
    
    def __enter__(self):
            self.connect()
            return self

    def __exit__(self, exc_type, exc_val, exc_tb):
        self.close()

    def is_server_online(self):
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(1)
            sock.connect((self.host, self.port))
            sock.sendall(b"ping\n")
            data = sock.recv(1024)
            sock.close()
            return b"pong" in data
        except:
            return False

    def connect(self):
        if self.is_server_online():
            print(f"[yellow]Server already running on {self.host}:{self.port}[/yellow]")
            return
        cmd = ["tmux", "new-session", "-d", "-s", self.tmux_session,
               f"python {SCRIPT_DIR}/robot_server.py --port {self.port_name} --host {self.host} --port-num {self.port} --id {self.robot_id}"]
        print(f"[green]Starting server in tmux session '{self.tmux_session}'...[/green]")
        subprocess.run(cmd, check=True)


    def disconnect(self):
        """优雅地关闭机械臂服务器，若失败则强制清理"""

        print(f"正在尝试断开 {self.host}:{self.port}...")
        
        # 1. 尝试通过网络发送退出指令
        try:
            with socket.create_connection((self.host, self.port), timeout=2) as sock:
                sock.sendall(b"quit\n")
                # 尝试读取确认信息（可选）
                # sock.recv(1024) 
            print("已向 Server 发送退出信号")
        except (ConnectionRefusedError, socket.timeout):
            print("无法连接到 Server (可能已关闭或响应超时)")
        except Exception as e:
            print(f"发送退出指令时发生意外错误: {e}")

        # 2. 延时给服务器一点退出时间
        time.sleep(0.5)

        # 3. 强制清理 Tmux 会话 (兜底方案)
        # 检查 tmux session 是否还存在
        check_tmux = subprocess.run(
            ["tmux", "has-session", "-t", self.tmux_session], 
            capture_output=True
        )
        
        if check_tmux.returncode == 0:
            print(f"正在清理残留的 Tmux 会话: {self.tmux_session}")
            subprocess.run(["tmux", "kill-session", "-t", self.tmux_session])
            print("Tmux 会话已关闭")
        else:
            print("未检测到残留会话，清理完成")

    def status(self):
        return self._get_client().send("status")

    def home(self):
        return self._get_client().send("home")

    def _get_client(self):
        if self.client is None:
            self.client = RobotClient(self.host, self.port)
            self.client.connect()
        return self.client

    def set_positions(self, **kwargs):
        cmd = "set " + " ".join(f"{k}={v}" for k, v in kwargs.items())
        return self._get_client().send(cmd)

    def safe_pos(self):
        return self.set_positions(**self._safe_pos)

    def free(self):
        self.safe_pos()
        time.sleep(1)
        return self.send_command("free")

    def lock(self):
        return self.send_command("lock")

    def send_command(self, cmd):
        resp = self._get_client().send(cmd)
        if resp.get("status") == "error" and "disconnected" in resp.get("message", "").lower():
            raise ConnectionError(resp.get("message"))
        return resp

    def get_observation(self):
        return self.send_command("get")

    def record(self, frequency=10, filename=None):
        pass

    def replay(self, speed=1.0, filename=None):
        pass

# --- Typer CLI 配置 ---

app = typer.Typer(
    help="🤖 Robot Agent 命令行管理工具",
    add_completion=False,
    rich_markup_mode="rich"
)

@app.callback()
def main(
    ctx: typer.Context,
    host: str = typer.Option("127.0.0.1", "--host", "-H", help="服务器 IP 地址"),
    port: int = typer.Option(8765, "--port", "-P", help="服务器通信端口")
):
    """
    [bold blue]Robot Agent CLI[/bold blue]
    
    所有子命令共用的参数（如 --host, --port）请放在子命令之前。
    示例: python agent.py --host 192.168.1.10 status
    """
    # 将实例化后的 agent 存入 context，供所有子命令使用
    ctx.obj = RobotAgent(host=host, port=port)

@app.command()
def connect(
    ctx: typer.Context,
    port_name: str = typer.Option("/dev/ttyACM1", "--port-name", "-p", help="机械臂串口路径"),
    robot_id: str = typer.Option("my_awesome_follower_arm", "--id", help="机器人唯一标识")
):
    """🚀 启动并连接机器人服务器 (tmux)"""
    agent: RobotAgent = ctx.obj
    agent.port_name = port_name
    agent.robot_id = robot_id
    agent.connect()


@app.command()
def disconnect(ctx: typer.Context):
    """🛑 停止机器人服务器并断开连接"""
    agent: RobotAgent = ctx.obj
    # 也可以在调用前加一点交互感
    print(f"[yellow]正在请求断开 {agent.host}:{agent.port} 的服务器...[/yellow]")
    agent.disconnect()

@app.command()
def status(ctx: typer.Context):
    """📊 查看机器人当前连接和锁定状态"""
    print(ctx.obj.status())

@app.command()
def get(ctx: typer.Context):
    """👁️ 获取当前关节数据 (Observations)"""
    print(ctx.obj.status()) # 实际应调用 get_observation

@app.command(name="set")
def set_pos(
    ctx: typer.Context, 
    args: list[str] = typer.Argument(..., help="关节参数，如 shoulder_pan.pos=1.1")
):
    """🎯 设置关节位置 (格式: key=value)"""
    kwargs = {}
    for arg in args:
        if "=" in arg:
            k, v = arg.split("=", 1)
            kwargs[k] = float(v)
    print(ctx.obj.set_positions(**kwargs))

@app.command()
def home(ctx: typer.Context):
    """🏠 机械臂各轴回零"""
    print(ctx.obj.home())

@app.command()
def safe(ctx: typer.Context):
    """🛡️ 移动到安全位置"""
    print(ctx.obj.safe_pos())

@app.command()
def free(ctx: typer.Context):
    """🔓 解锁扭矩 (先移动到安全位置)"""
    print(ctx.obj.free())

@app.command()
def lock(ctx: typer.Context):
    """🔒 锁定扭矩"""
    print(ctx.obj.lock())

@app.command()
def record(
    ctx: typer.Context,
    frequency: int = typer.Option(10, "--freq", "-f", help="采集频率 (Hz)"),
    filename: Optional[str] = typer.Option(None, "--out", "-o", help="保存文件名")
):
    """⏺️ 开始录制示教动作 (按 Enter 停止)"""
    ctx.obj.record(frequency, filename)

@app.command()
def replay(
    ctx: typer.Context,
    speed: float = typer.Option(1.0, "--speed", "-s", help="回放倍速"),
    filename: Optional[str] = typer.Option(None, "--file", "-r", help="指定回放文件")
):
    """▶️ 回放已录制的动作数据"""
    ctx.obj.replay(speed, filename)

@app.command()
def test():
    """🛠️ 硬件自检 (端口与相机)"""
    print("[bold]开始硬件测试...[/bold]")
    test_arm_port()
    test_camera()

if __name__ == "__main__":
    app()